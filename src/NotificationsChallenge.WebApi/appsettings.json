{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidIssuer": "MyBackend",
        "ValidAudiences": [
          "MyFrontend"
        ],
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true,
        "ValidateIssuerSigningKey": true
      }
    }
  },
  
  "JwtSecretKey": "Set in environment variables",
  
  "ConnectionStrings": {
    "DefaultConnection": "Set in environment variables"
  }
}